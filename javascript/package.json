{
  "name": "template-aws-lambda-javascript",
  "version": "1.0.0",
  "description": "AWS Lambda JavaScript ESM template with Powertools and Middy",
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.js --bundle --platform=node --target=node22 --format=esm --outfile=dist/handler.js",
    "postbuild": "node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'module'}))\"",
    "test": "vitest run",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2",
    "@aws-lambda-powertools/metrics": "^2",
    "@aws-lambda-powertools/tracer": "^2",
    "@aws-sdk/client-dynamodb": "^3",
    "@aws-sdk/client-ssm": "^3",
    "@middy/core": "^5",
    "@middy/http-error-handler": "^5",
    "@middy/http-json-body-parser": "^5",
    "@middy/ssm": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "esbuild": "^0.25",
    "eslint": "^9",
    "vitest": "^2"
  }
}
